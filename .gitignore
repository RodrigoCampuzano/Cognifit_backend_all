# ============================================================
# CogniFit — .gitignore
# ============================================================

docs/pdfs
docs/contexto
docs/APP_OVERVIEW.md
docs/ADR_CogniFit_Escolar.md
docs/C3_validacion_entradas
docs/reporte alonso
docs/Cognifit-C3-Proyecto_Integrador-Validacion_de_entradas_de_datos.zip
# --- App móvil (Flutter) — no versionada -------------------
app/

# --- Variables de entorno / secretos (NO subir) ------------
.env
.env.*
# ...pero sí versionar las plantillas de ejemplo:
!.env.example
!.env*.example

# --- Python ------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.Python

# Entornos virtuales
.venv/
venv/
env/
ENV/

# --- Test / cobertura / cachés -----------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# --- Logs y datos de runtime -------------------------------
*.log
logs/
reports_storage/
*.sqlite
*.sqlite3
*.db

# --- Sistema operativo / editor ----------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# --- Docker / Caddy runtime --------------------------------
caddy_data/
caddy_config/

# NOTA: los modelos ML (Pln/.../*.pkl) SÍ se versionan a propósito;
# no se ignoran aquí porque el diagnosis_service los necesita en build.

# --- Excepción: plantillas de despliegue ---
# La regla 'env/' (virtualenv) capturaba deploy/env/; re-incluir esa carpeta.
!deploy/env/
!deploy/env/**

# Capturas generadas por las pruebas de integración (el original vive en
# docs/C3_validacion_entradas/img/, ya recortado).
app/cognifit_mobile/build/capturas/
