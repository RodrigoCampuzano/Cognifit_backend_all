# ============================================================
# SERVICIO: diagnosis_service  (PLN + ML, privado, puerto 8001)
# ============================================================
# Este servicio NO lee variables de entorno de la aplicación:
# carga los modelos .pkl y el léxico desde su propio código/archivos.
#
# Oracle/compose: NO necesita ninguna variable. Escucha en 8001 (fijo).
#
# Railway: la red privada es IPv6 y el puerto lo asigna $PORT, por eso se
# fija PORT y el Start Command enlaza a :: y $PORT.
#   Start Command: uvicorn app.main:app --host :: --port $PORT
#   Healthcheck Path: /health
# ============================================================

# Solo para Railway:
PORT=8001
