# ============================================================
# SERVICIO: recommendation_service  (rutas adaptativas, privado, puerto 8002)
# ============================================================
# Este servicio NO lee variables de entorno de la aplicación:
# carga el banco de ejercicios desde su propio archivo JSON.
#
# Oracle/compose: NO necesita ninguna variable. Escucha en 8002 (fijo).
#
# Railway:
#   Start Command: uvicorn app.main:app --host :: --port $PORT
#   Healthcheck Path: /health
# ============================================================

# Solo para Railway:
PORT=8002
