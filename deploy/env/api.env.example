# ============================================================
# SERVICIO: api  (FastAPI, público)
# ============================================================
# Oracle/compose: este archivo se copia a deploy/.env.prod y lo lee el compose.
# Railway: pega estas variables en Settings → Variables del servicio `api`.
#
# Genera los secretos:  openssl rand -base64 48  /  openssl rand -base64 32
# ============================================================

APP_ENV=production
PROJECT_NAME=CogniFit Escolar API
API_V1_PREFIX=/api/v1
DEBUG=false
ENABLE_SWAGGER=false
ALLOW_PUBLIC_REGISTRATION=false

# --- Base de datos (ver deploy/env/database.env.example) ---
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
SYNC_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DB_ENCRYPTION_KEY=CAMBIA_ESTO_openssl_rand_base64_32

# --- Redis ---
# Oracle/compose: redis interno    | Railway: ${{Redis.REDIS_URL}}
REDIS_URL=redis://redis:6379/0

# --- Servicios PLN ---
# Oracle/compose: nombres del compose
DIAGNOSIS_SERVICE_URL=http://diagnosis_service:8001
RECOMMENDATION_SERVICE_URL=http://recommendation_service:8002
# Railway (red privada): usa estos en su lugar
# DIAGNOSIS_SERVICE_URL=http://diagnosis.railway.internal:8001
# RECOMMENDATION_SERVICE_URL=http://recommendation.railway.internal:8002
PLN_TIMEOUT_SECONDS=10.0
PLN_RETRIES=1
PLN_FALLBACK_ENABLED=true

# --- Seguridad / JWT ---
JWT_SECRET_KEY=CAMBIA_ESTO_openssl_rand_base64_48
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_PEPPER=
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2
FIELD_ENCRYPTION_KEY=

# --- CORS (dominios del frontend, coma-separado) ---
CORS_ORIGINS=https://tu-frontend.vercel.app

RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=INFO
