# ============================================================
# CogniFit — Variables de PRODUCCIÓN (VM Oracle + Neon)
# Copia este archivo a deploy/.env.prod y rellena los valores.
#   cp deploy/.env.prod.example deploy/.env.prod
# NUNCA subas .env.prod a git.
# ============================================================

APP_ENV=production
PROJECT_NAME=CogniFit Escolar API
API_V1_PREFIX=/api/v1
DEBUG=false
ENABLE_SWAGGER=false
ALLOW_PUBLIC_REGISTRATION=false

# --- Base de datos: Neon -----------------------------------
# Copia la "Connection string" de Neon (Dashboard > Connect).
# Neon EXIGE SSL: añade ?sslmode=require al final.
# Usa el host SIN "-pooler" para las migraciones; con "-pooler" para la app.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
SYNC_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Clave para cifrado de campos PII en DB (pgcrypto). Genera una fuerte:
#   openssl rand -base64 32
DB_ENCRYPTION_KEY=CAMBIA_ESTO_clave_fuerte_aleatoria

# --- Redis (local en la misma VM) --------------------------
REDIS_URL=redis://redis:6379/0

# --- CORS: dominios del frontend ---------------------------
# Pon el dominio real de tu app Flutter web (Vercel) y/o tu dominio.
CORS_ORIGINS=https://tu-frontend.vercel.app

# --- Seguridad / JWT ---------------------------------------
# Genera con: openssl rand -base64 48
JWT_SECRET_KEY=CAMBIA_ESTO_minimo_32_bytes_aleatorios
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_PEPPER=

ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2

FIELD_ENCRYPTION_KEY=
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=INFO

# --- Integración con servicios PLN (red interna de Docker) -
DIAGNOSIS_SERVICE_URL=http://diagnosis_service:8001
RECOMMENDATION_SERVICE_URL=http://recommendation_service:8002
PLN_TIMEOUT_SECONDS=10.0
PLN_RETRIES=1
PLN_FALLBACK_ENABLED=true
