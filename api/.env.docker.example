APP_ENV=development
PROJECT_NAME=CogniFit Escolar API
API_V1_PREFIX=/api/v1
DEBUG=false
ENABLE_SWAGGER=true
ALLOW_PUBLIC_REGISTRATION=true

DATABASE_URL=postgresql+asyncpg://cognifit_api:cognifit_api_dev_password@postgres:5432/cognifit
SYNC_DATABASE_URL=postgresql://cognifit_api:cognifit_api_dev_password@postgres:5432/cognifit
DB_ENCRYPTION_KEY=change-this-db-field-key

REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:8000

JWT_SECRET_KEY=change-this-docker-secret-at-least-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_PEPPER=

ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2

FIELD_ENCRYPTION_KEY=
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=INFO

CONEKTA_PRIVATE_KEY=key_dummy_change_me
CONEKTA_PUBLIC_KEY=key_dummy_change_me
CONEKTA_WEBHOOK_SECRET=change-this-webhook-secret
CONEKTA_API_VERSION=2.1.0
CONEKTA_BASE_URL=https://api.conekta.io

DIAGNOSIS_SERVICE_URL=http://diagnosis_service:8001
RECOMMENDATION_SERVICE_URL=http://recommendation_service:8002
PLN_TIMEOUT_SECONDS=10.0
PLN_RETRIES=1
PLN_FALLBACK_ENABLED=true
