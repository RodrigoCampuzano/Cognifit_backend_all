# ============================================================
# CONFIGURACIÓN DE BASE DE DATOS — Neon (o Postgres de Railway)
# ============================================================
# Estas variables las consume el servicio `api` (no hay un servicio DB propio).
# Se incluyen aquí aparte solo para documentar la configuración de la DB.
#
# La app necesita DOS variantes de la misma URL:
#   - DATABASE_URL       → async, DEBE empezar con  postgresql+asyncpg://
#   - SYNC_DATABASE_URL  → sync,  empieza con        postgresql://
#
# Neon EXIGE SSL → añade  ?sslmode=require  al final de ambas.
# Para la APP usa el host CON "-pooler"; para correr migraciones, el host SIN "-pooler".
# ============================================================

# --- Neon (recomendado, gratis, no pausa) ---
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
SYNC_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# --- Alternativa: Postgres de Railway (referencias del plugin) ---
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# SYNC_DATABASE_URL=${{Postgres.DATABASE_URL}}

# Clave para cifrado de campos PII en DB (pgcrypto). Genera: openssl rand -base64 32
DB_ENCRYPTION_KEY=CAMBIA_ESTO_clave_fuerte_aleatoria

# ------------------------------------------------------------
# Carga del schema (una sola vez, con el host SIN -pooler):
#   export PGURL="postgresql://USER:PASS@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"
#   psql "$PGURL" -v ON_ERROR_STOP=1 -f database/schema.sql
#   psql "$PGURL" -v ON_ERROR_STOP=1 -f database/002_pln_integration.sql
#   psql "$PGURL" -v ON_ERROR_STOP=1 -f database/003_sync_exercises_from_bank.sql
#   psql "$PGURL" -v ON_ERROR_STOP=1 -f database/004_user_roles_parent_specialist.sql
# Verificar:
#   psql "$PGURL" -c "\dn"
#   psql "$PGURL" -c "SELECT count(*) FROM intervention.exercises;"
# ------------------------------------------------------------
